{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@edu/types": ["../../packages/types/src/index.ts"],
      "@edu/ui": ["../../packages/ui/src/index.ts"],
      "@edu/utils": ["../../packages/utils/src/index.ts"],
      "@edu/validators": ["../../packages/validators/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
