## Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# Comma-separated list. Use * only for quick local testing.
CORS_ORIGIN=http://localhost:3000

## Database (Postgres)
# Example:
# postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edu_portal?schema=public

## Auth (JWT)
# HS256 secret used to verify `Authorization: Bearer <jwt>`.
JWT_SECRET=change-me-super-secret-at-least-16-chars

## Seed (dev)
SEED_ADMIN_PASSWORD=admin12345

## Web
# Used by Next.js pages to call the API during local development.
NEXT_PUBLIC_API_URL=http://localhost:3001

ALLOW_DEV_MOCK_AUTH=false
